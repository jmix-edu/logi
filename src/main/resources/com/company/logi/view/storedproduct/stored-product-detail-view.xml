<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://storedProductDetailView.title"
      focusComponent="form">
    <data>
        <instance id="storedProductDc"
                  class="com.company.logi.entity.StoredProduct">
            <fetchPlan extends="_base">
                <property name="product" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="storedProductDl"/>
        </instance>
        <collection id="productsDc" class="com.company.logi.entity.Product">
            <fetchPlan extends="_base"/>
            <loader id="productsDl" readOnly="true">
                <query>
                    <![CDATA[select e from Product e]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveCloseAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <formLayout id="form" dataContainer="storedProductDc">
            <responsiveSteps>
                <responsiveStep minWidth="0" columns="1"/>
                <responsiveStep minWidth="40em" columns="2"/>
            </responsiveSteps>

            <entityComboBox id="productsComboBox" itemsContainer="productsDc" dataContainer="storedProductDc"
                            property="product">
                <actions>
                    <action id="entityClear" type="entity_clear"/>
                    <action id="entityLookup" type="entity_lookup"/>
                </actions>
            </entityComboBox>
            <textField id="amountField" property="amount"/>
        </formLayout>
        <hbox id="detailActions">
            <button id="saveAndCloseButton" action="saveCloseAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>
