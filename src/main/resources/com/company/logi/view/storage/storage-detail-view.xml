<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://storageDetailView.title"
      focusComponent="form">
    <data>
        <instance id="storageDc"
                  class="com.company.logi.entity.Storage">
            <fetchPlan extends="_base">
                <property name="companyUnit" fetchPlan="_base"/>
                <property name="storedProducts" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="storageDl"/>
            <collection id="storedProductsDc" property="storedProducts"/>
        </instance>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveCloseAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <formLayout id="form" dataContainer="storageDc">
            <responsiveSteps>
                <responsiveStep minWidth="0" columns="1"/>
                <responsiveStep minWidth="40em" columns="2"/>
            </responsiveSteps>
            <textField id="nameField" property="name"/>
            <textField id="codeField" property="code"/>
            <textField id="operationsField" property="operations"/>
            <textArea id="addressField" height="9.5em" property="address"/>
            <entityPicker id="companyUnitField" property="companyUnit">
                <actions>
                    <action id="entityLookupAction" type="entity_lookup"/>
                    <action id="entityClearAction" type="entity_clear"/>
                </actions>
            </entityPicker>
            <textField id="locationField" property="location">
                <suffix>
                    <button id="locationLookupBtn"
                            icon="MAP_MARKER"
                            classNames="text-success"/>
                </suffix>
            </textField>
        </formLayout>
        <hbox id="storedProductsButtonsPanel" classNames="buttons-panel">
            <button action="storedProductsDataGrid.createAction"/>
            <button action="storedProductsDataGrid.editAction"/>
            <button action="storedProductsDataGrid.removeAction"/>
        </hbox>
        <dataGrid id="storedProductsDataGrid" dataContainer="storedProductsDc" width="100%" height="100%">
            <actions>
                <action id="createAction" type="list_create">
                    <properties>
                        <property name="openMode" value="DIALOG"/>
                    </properties>
                </action>
                <action id="editAction" type="list_edit">
                    <properties>
                        <property name="openMode" value="DIALOG"/>
                    </properties>
                </action>
                <action id="removeAction" type="list_remove"/>
            </actions>
            <columns>
                <column property="product"/>
                <column property="amount"/>
            </columns>
        </dataGrid>
        <hbox id="detailActions">
            <button id="saveAndCloseButton" action="saveCloseAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>
